<?xml version="1.0" encoding="utf-8" ?>
<toolbox>
	<parametre id="defaultCategories">CAT_LOGIC,CAT_TIME,CAT_LOOPS,CAT_IO,CAT_SERIAL_MESSAGE,CAT_CONTROLS,CAT_LED,CAT_BUZZER,CAT_MATH,CAT_TEXT,CAT_VARIABLES,CAT_SENSOR,CAT_SERVO,CAT_DISPLAY</parametre>

	<!-- ── Logic ──────────────────────────────────────────────────────────────── -->
	<!-- "How do I begin and make choices?" — setup/timing plus if/else -->
	<category name="Logic" id="CAT_LOGIC" colour="#FFAB19">
		<!-- base_loop removed: workspace starts with base_setup_loop; use Loop category for repeat/while -->
		<!-- If only — click the gear to add else or else-if -->
		<!-- Real nested blocks (not shadows) so compare + numbers stay visible like one piece -->
		<block type="controls_if">
			<value name="IF0">
				<block type="logic_compare">
					<value name="A">
						<block type="math_number">
							<field name="NUM">0</field>
						</block>
					</value>
					<field name="OP">LT</field>
					<value name="B">
						<block type="math_number">
							<field name="NUM">100</field>
						</block>
					</value>
				</block>
			</value>
		</block>
		<!-- If–else (then and else always visible) -->
		<block type="controls_ifelse">
			<value name="IF0">
				<block type="logic_compare">
					<value name="A">
						<block type="math_number">
							<field name="NUM">0</field>
						</block>
					</value>
					<field name="OP">LT</field>
					<value name="B">
						<block type="math_number">
							<field name="NUM">100</field>
						</block>
					</value>
				</block>
			</value>
		</block>
		<block type="logic_compare"></block>
		<block type="logic_operation"></block>
		<block type="logic_boolean"></block>
	</category>

	<!-- ── Time ───────────────────────────────────────────────────────────────── -->
	<category name="Time" id="CAT_TIME" colour="#3B82F6">
		<block type="base_delay">
			<value name="DELAY_TIME">
				<shadow type="math_number">
					<field name="NUM">100</field>
				</shadow>
			</value>
		</block>
		<block type="base_delay_sec">
			<value name="DELAY_TIME">
				<shadow type="math_number">
					<field name="NUM">1</field>
				</shadow>
			</value>
		</block>
	</category>

	<!-- ── Loop ───────────────────────────────────────────────────────────────── -->
	<!-- "How do I do it again?" — repeat actions -->
	<category name="Loop" id="CAT_LOOPS" colour="#FFD500">
		<block type="controls_repeat">
			<value name="TIMES">
				<shadow type="math_number">
					<field name="NUM">10</field>
				</shadow>
			</value>
		</block>
		<block type="controls_whileUntil"></block>
	</category>

	<!-- ── Math ───────────────────────────────────────────────────────────────── -->
	<!-- "How do I use numbers?" — core math + map utility -->
	<category name="Math" id="CAT_MATH" colour="#40BF4A">
		<block type="math_number"></block>
		<block type="math_arithmetic"></block>
		<block type="math_random_int">
			<value name="FROM">
				<shadow type="math_number">
					<field name="NUM">1</field>
				</shadow>
			</value>
			<value name="TO">
				<shadow type="math_number">
					<field name="NUM">100</field>
				</shadow>
			</value>
		</block>
		<block type="base_map">
			<value name="NUM">
				<shadow type="math_number">
					<field name="NUM">0</field>
				</shadow>
			</value>
			<value name="DMAX">
				<shadow type="math_number">
					<field name="NUM">255</field>
				</shadow>
			</value>
		</block>
	</category>

	<!-- ── Text (string & char) ─────────────────────────────────────────────── -->
	<category name="Text" id="CAT_TEXT" colour="#9966FF">
		<block type="basic_text_string">
			<field name="TEXT"></field>
		</block>
		<block type="basic_text_char">
			<field name="CHAR">A</field>
		</block>
	</category>

	<!-- ── Variables ──────────────────────────────────────────────────────────── -->
	<!-- "How do I remember things?" — auto-generated by Blockly -->
	<category name="Variables" id="CAT_VARIABLES" custom="VARIABLE" colour="#FF8C1A"></category>

	<!-- ── Arduino (pins + Serial) ───────────────────────────────────────────── -->
	<!-- Digital/analog pins, PWM, and Serial — beginner-friendly under one label -->
	<category name="Arduino" id="CAT_IO" colour="#00979D">
		<!-- Arduino sketch shell: setup runs once, loop repeats -->
		<block type="base_setup_loop"></block>
		<!-- Core 6: set pin mode before read/write blocks -->
		<block type="inout_digital_mode"></block>
		<!-- Make things happen (on-board LED lives under LED category) -->
		<block type="inout_digital_write_validator"></block>
		<block type="inout_onoff"></block>
		<block type="inout_digital_read_validator"></block>
		<block type="inout_PWM_write">
			<value name="NUM">
				<shadow type="math_number">
					<field name="NUM">50</field>
				</shadow>
			</value>
		</block>
		<block type="inout_analog_read_validator"></block>
		<!-- tone_notime / notone removed: use Buzzer category (basic_passive_tone, basic_passive_stop) -->
	</category>

	<!-- ── Serial Message (monitor talk) ─────────────────────────────────────── -->
	<category name="Serial Message" id="CAT_SERIAL_MESSAGE" colour="#00979D">
		<block type="serial_init"></block>
		<block type="serial_print">
			<value name="CONTENT">
				<shadow type="text">
					<field name="TEXT">Hello</field>
				</shadow>
			</value>
		</block>
		<block type="serial_println">
			<value name="CONTENT">
				<shadow type="text">
					<field name="TEXT">World!</field>
				</shadow>
			</value>
		</block>
		<block type="serial_available"></block>
		<block type="serial_read"></block>
		<block type="basic_serial_read_text"></block>
		<block type="serial_write">
			<value name="CONTENT">
				<shadow type="text">
					<field name="TEXT">A</field>
				</shadow>
			</value>
		</block>
	</category>

	<!-- ── Controls (interactive inputs) ─────────────────────────────────────── -->
	<category name="Controls" id="CAT_CONTROLS" colour="#5E60CE">
		<category name="Push Button" id="CAT_CONTROLS_BUTTON" colour="#5E60CE">
			<block type="basic_button_setup">
				<field name="PIN">2</field>
			</block>
			<block type="basic_button_state">
				<field name="STATE">PRESSED</field>
				<field name="PIN">2</field>
			</block>
		</category>
		<category name="Joystick" id="CAT_CONTROLS_JOYSTICK" colour="#5E60CE">
			<block type="basic_joystick_setup">
				<field name="XPIN">A0</field>
				<field name="YPIN">A1</field>
				<field name="BPIN">2</field>
			</block>
			<block type="basic_joystick_x">
				<field name="PIN">A0</field>
			</block>
			<block type="basic_joystick_y">
				<field name="PIN">A1</field>
			</block>
			<block type="basic_joystick_button">
				<field name="PIN">2</field>
			</block>
		</category>
		<category name="Potentiometer" id="CAT_CONTROLS_POT" colour="#5E60CE">
			<block type="basic_potentiometer_setup">
				<field name="PIN">A0</field>
			</block>
			<block type="basic_potentiometer_read">
				<field name="PIN">A0</field>
			</block>
		</category>
		<category name="Switch" id="CAT_CONTROLS_SWITCH" colour="#5E60CE">
			<block type="basic_switch_setup">
				<field name="PIN">2</field>
			</block>
			<block type="basic_switch_state">
				<field name="STATE">ON</field>
				<field name="PIN">2</field>
			</block>
		</category>
	</category>

	<!-- ── LED ─────────────────────────────────────────────────────────────────── -->
	<category name="LED" id="CAT_LED" colour="#FF5722">
		<!-- STEM: declare the LED pin in setup (pinMode). Drag into the setup section of base_setup_loop. -->
		<block type="basic_led_setup">
			<field name="PIN">13</field>
		</block>
		<category name="NeoPixel" id="CAT_LED_NEOPIXEL" colour="#FF5722">
			<block type="basic_neopixel_strip_setup">
				<field name="PIN">2</field>
				<field name="COUNT">8</field>
			</block>
			<block type="basic_neopixel_single">
				<field name="PIN">2</field>
				<field name="COLOR">#ff0000</field>
			</block>
			<block type="basic_neopixel_set_brightness">
				<field name="PIN">2</field>
				<field name="BRIGHTNESS">64</field>
			</block>
			<block type="basic_neopixel_fill">
				<field name="PIN">2</field>
				<field name="COLOR">#00ff66</field>
				<field name="COUNT">8</field>
			</block>
			<block type="basic_neopixel_show">
				<field name="PIN">2</field>
			</block>
			<block type="basic_neopixel_clear">
				<field name="PIN">2</field>
			</block>
			<block type="basic_neopixel_color_wipe">
				<field name="PIN">2</field>
				<field name="COLOR">#ff6600</field>
				<field name="COUNT">8</field>
				<field name="DELAY">60</field>
			</block>
			<block type="basic_neopixel_theater_chase">
				<field name="PIN">2</field>
				<field name="COLOR">#ffffff</field>
				<field name="COUNT">8</field>
				<field name="DELAY">80</field>
				<field name="ROUNDS">5</field>
			</block>
			<block type="basic_neopixel_rainbow_cycle">
				<field name="PIN">2</field>
				<field name="COUNT">8</field>
				<field name="DELAY">20</field>
				<field name="CYCLES">1</field>
			</block>
		</category>
		<block type="basic_led_pin">
			<field name="STAT">HIGH</field>
			<field name="PIN">13</field>
		</block>
		<block type="inout_buildin_led"></block>
		<block type="led_blink">
			<value name="DELAY">
				<shadow type="math_number">
					<field name="NUM">500</field>
				</shadow>
			</value>
		</block>
		<block type="basic_led_blink_pattern">
			<field name="PIN">13</field>
			<value name="ON_MS">
				<shadow type="math_number">
					<field name="NUM">500</field>
				</shadow>
			</value>
			<value name="OFF_MS">
				<shadow type="math_number">
					<field name="NUM">500</field>
				</shadow>
			</value>
		</block>
		<block type="basic_led_brightness">
			<field name="PIN">9</field>
			<value name="NUM">
				<shadow type="math_number">
					<field name="NUM">50</field>
				</shadow>
			</value>
		</block>
	</category>

	<!-- ── Buzzer ─────────────────────────────────────────────────────────────── -->
	<category name="Buzzer" id="CAT_BUZZER" colour="#6B8E23">
		<block type="basic_buzzer_setup">
			<field name="PIN">7</field>
		</block>
		<block type="basic_active_buzzer">
			<field name="STAT">HIGH</field>
			<field name="PIN">7</field>
		</block>
		<block type="basic_buzzer_beep">
			<field name="PIN">7</field>
			<value name="ON_MS">
				<shadow type="math_number">
					<field name="NUM">100</field>
				</shadow>
			</value>
			<value name="OFF_MS">
				<shadow type="math_number">
					<field name="NUM">100</field>
				</shadow>
			</value>
		</block>
		<block type="basic_passive_tone">
			<field name="PIN">8</field>
			<value name="FREQ">
				<shadow type="math_number">
					<field name="NUM">440</field>
				</shadow>
			</value>
			<value name="DUR">
				<shadow type="math_number">
					<field name="NUM">200</field>
				</shadow>
			</value>
		</block>
		<block type="basic_passive_stop">
			<field name="PIN">8</field>
		</block>
	</category>

	<!-- ── Sensors ────────────────────────────────────────────────────────────── -->
	<!-- "How do I read sensor data?" — grouped by sensor name -->
	<category name="Sensors" id="CAT_SENSOR" colour="#9B59B6">
		<category name="LDR" id="CAT_SENSOR_LDR" colour="#9B59B6">
			<block type="basic_ldr_setup">
				<field name="PIN">A0</field>
			</block>
			<!-- Light sensor (LDR) — returns 0-1023, default A0 -->
			<block type="basic_ldr_read">
				<field name="PIN">A0</field>
			</block>
		</category>
		<category name="IR" id="CAT_SENSOR_IR" colour="#9B59B6">
			<block type="basic_ir_setup">
				<field name="PIN">2</field>
			</block>
			<!-- IR obstacle sensor — returns true/false, default pin 2 -->
			<block type="basic_ir_detect">
				<field name="PIN">2</field>
			</block>
		</category>
		<category name="DHT11" id="CAT_SENSOR_DHT11" colour="#9B59B6">
			<block type="basic_dht_setup">
				<field name="PIN">2</field>
			</block>
			<!-- Temperature from DHT11 — returns °C, default pin 2 -->
			<block type="basic_dht_temp">
				<field name="PIN">2</field>
			</block>
			<!-- Humidity from DHT11 — returns %, default pin 2 -->
			<block type="basic_dht_humid">
				<field name="PIN">2</field>
			</block>
		</category>
		<category name="Ultrasonic" id="CAT_SENSOR_ULTRASONIC" colour="#9B59B6">
			<block type="basic_ultrasonic_setup">
				<field name="TRIG">9</field>
				<field name="ECHO">10</field>
			</block>
			<!-- Ultrasonic distance — returns cm, standard HC-SR04 wiring: Trig=9 Echo=10 -->
			<block type="basic_ultrasonic">
				<field name="TRIG">9</field>
				<field name="ECHO">10</field>
			</block>
		</category>
	</category>

	<!-- ── Actuators ──────────────────────────────────────────────────────────── -->
	<!-- "How do I move things?" — single servo block + LED helper -->
	<category name="Actuators" id="CAT_SERVO" colour="#27AE60">
		<block type="basic_servo_setup">
			<field name="PIN">9</field>
		</block>
		<!-- All-in-one servo move: attaches + moves in one block.
		     The angle input accepts any Number — sensor value, variable, or map() expression. -->
		<block type="basic_servo_move">
			<field name="PIN">9</field>
			<value name="ANGLE">
				<shadow type="basic_servo_angle">
					<field name="DEG">90</field>
				</shadow>
			</value>
		</block>
		<block type="basic_servo_angle"></block>
	</category>

	<!-- ── Display: LCD + OLED (nested) ───────────────────────────────────────── -->
	<category name="Display" id="CAT_DISPLAY" colour="#2980B9">
		<category name="LCD (I2C)" id="CAT_DISPLAY_LCD" colour="#2980B9">
			<block type="basic_lcd_setup">
				<field name="ADDR">0x27</field>
			</block>
			<block type="basic_lcd_show_line">
				<field name="LINE">1</field>
				<value name="TEXT">
					<shadow type="text">
						<field name="TEXT">Hello</field>
					</shadow>
				</value>
			</block>
			<block type="lcd_i2c_lcdclear"></block>
			<block type="lcd_i2c_lcdwrite">
				<value name="TEXT">
					<shadow type="text">
						<field name="TEXT">Hi</field>
					</shadow>
				</value>
				<value name="COL">
					<shadow type="math_number">
						<field name="NUM">0</field>
					</shadow>
				</value>
				<value name="LIG">
					<shadow type="math_number">
						<field name="NUM">0</field>
					</shadow>
				</value>
			</block>
		</category>
		<category name="OLED" id="CAT_DISPLAY_OLED" colour="#2980B9">
			<block type="SSD1306_init_basic">
				<field name="ADDR">0x3C</field>
			</block>
			<block type="basic_oled_screen_4lines">
				<value name="L1">
					<shadow type="text"><field name="TEXT">Line 1</field></shadow>
				</value>
				<value name="L2">
					<shadow type="text"><field name="TEXT">Line 2</field></shadow>
				</value>
				<value name="L3">
					<shadow type="text"><field name="TEXT"></field></shadow>
				</value>
				<value name="L4">
					<shadow type="text"><field name="TEXT"></field></shadow>
				</value>
			</block>
			<block type="SSD1306_clearDisplay"></block>
			<block type="SSD1306_display"></block>
			<block type="SSD1306_setTextSize">
				<value name="SIZE">
					<shadow type="math_number"><field name="NUM">1</field></shadow>
				</value>
			</block>
			<block type="SSD1306_setTextColour"></block>
			<block type="SSD1306_setCursor">
				<value name="XPOS">
					<shadow type="math_number"><field name="NUM">0</field></shadow>
				</value>
				<value name="YPOS">
					<shadow type="math_number"><field name="NUM">0</field></shadow>
				</value>
			</block>
			<block type="SSD1306_print">
				<value name="STRING">
					<shadow type="text"><field name="TEXT">Hello</field></shadow>
				</value>
			</block>
			<block type="SSD1306_println">
				<value name="STRING">
					<shadow type="text"><field name="TEXT">World</field></shadow>
				</value>
			</block>
			<block type="SSD1306_write">
				<value name="CHAR">
					<shadow type="text"><field name="TEXT">A</field></shadow>
				</value>
			</block>
			<block type="SSD1306_invertDisplay">
				<value name="ENABLE">
					<shadow type="logic_boolean"><field name="BOOL">TRUE</field></shadow>
				</value>
			</block>
			<block type="SSD1306_startscroll">
				<value name="START_ROW">
					<shadow type="math_number"><field name="NUM">0</field></shadow>
				</value>
				<value name="END_ROW">
					<shadow type="math_number"><field name="NUM">7</field></shadow>
				</value>
			</block>
			<block type="SSD1306_stopscroll"></block>
		</category>
	</category>

</toolbox>

# Sarvam API subscription key (server only — create at https://dashboard.sarvam.ai/)
# Paste the raw key only (no "quotes"). After changing env on Vercel, redeploy.
SARVAM_API_KEY=

# Optional alias (same value as SARVAM_API_KEY if you prefer this name in Vercel)
# SARVAM_API_SUBSCRIPTION_KEY=

# Optional: model id (default sarvam-30b). See https://docs.sarvam.ai/
# SARVAM_MODEL=sarvam-30b

# Optional: max output tokens (default 4096). Too low = answers cut off mid-sentence.
# SARVAM_MAX_OUTPUT_TOKENS=4096

# Comma-separated Bearer tokens clients must send: Authorization: Bearer <token>
# If empty, ANY request is accepted (dev only — set at least one token in production)
AI_CLIENT_TOKENS=

# Or a single client token (Vercel-friendly name). Used if AI_CLIENT_TOKENS is unset.
# AI_CLIENT_TOKEN=
